generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PRINCIPAL
  TEACHER
  STUDENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  name      String
  phone     String?
  role      Role       @default(STUDENT)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  resetToken       String?
  resetTokenExpiry DateTime?

  instituteId String?
  institute   Institute? @relation("InstituteUsers", fields: [instituteId], references: [id])
  
  managedInstitute Institute? @relation("PrincipalOf")
  
  createdBy Int?
  permissions String[] @default([])

  taughtCourses Course[] @relation("TeacherCourses")

  enrollments Enrollment[]
  attendance  Attendance[]
  alerts      Alert[]
  className   String?
}

model Institute {
  id             String   @id @default(uuid())
  name           String
  maxClass       Int      @default(0)
  address        String?
  phone          String?
  principalId    Int      @unique
  principal      User     @relation("PrincipalOf", fields: [principalId], references: [id])
  users          User[]   @relation("InstituteUsers")
  courses        Course[] @relation("InstituteCourses")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lmsSharedSecret String?
  lmsAllowedDomain String?
}


model Course {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  teacherId   Int?
  teacher     User?    @relation("TeacherCourses", fields: [teacherId], references: [id])
  
  instituteId String?
  institute   Institute? @relation("InstituteCourses", fields: [instituteId], references: [id])
  className   String?

  days        String[]   @default([])
  time        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments Enrollment[]
  attendance  Attendance[]
}

model Enrollment {
  id        Int      @id @default(autoincrement())
  studentId Int
  courseId  Int
  student   User     @relation(fields: [studentId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])
  createdAt DateTime @default(now())

  @@unique([studentId, courseId])
}

model Attendance {
  id        Int              @id @default(autoincrement())
  studentId Int
  courseId  Int
  date      DateTime         @default(now())
  markedAt  DateTime         @default(now())
  status    AttendanceStatus @default(PRESENT)
  location  String?
  notes     String?
  student   User             @relation(fields: [studentId], references: [id])
  course    Course           @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId, date])
}

model Alert {
  id        Int      @id @default(autoincrement())
  studentId Int
  message   String
  dateTime  DateTime @default(now())
  isRead    Boolean  @default(false)
  student   User     @relation(fields: [studentId], references: [id])
}