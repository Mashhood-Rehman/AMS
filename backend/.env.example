# Database (Neon) — use verify-full to match current pg behavior and silence SSL warnings
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=verify-full&channel_binding=require

# Email on Render: SMTP ports 465/587 are blocked — use Resend (HTTPS API)
# https://resend.com — create API key, verify domain (or use onboarding@resend.dev for testing)
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=AMS Attendance <noreply@yourdomain.com>

# Production frontend URL (password reset links)
FRONTEND_URL=https://your-frontend.vercel.app

# Optional: local development with Gmail SMTP (not for Render)
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_gmail_app_password
# SMTP_FORCE_IPV4=true
